{
  "name": "nuxt3-primevue-starter",
  "type": "module",
  "version": "2.2.6",
  "license": "MIT",
  "scripts": {
    "build": "node --import ./register-loader.mjs ./node_modules/nuxt/bin/nuxt.mjs build",
    "dev": "node --import ./register-loader.mjs ./node_modules/nuxt/bin/nuxt.mjs dev --host 0.0.0.0",
    "generate": "node --import ./register-loader.mjs ./node_modules/nuxt/bin/nuxt.mjs generate",
    "preview": "node --import ./register-loader.mjs ./node_modules/nuxt/bin/nuxt.mjs preview",
    "module": "nuxi init -t module my-module",
    "start": "node .output/server/index.mjs",
    "lint": "eslint ./app",
    "lint:fix": "eslint --fix ./app",
    "test:ui": "vitest --ui",
    "test:unit": "vitest --run --reporter verbose",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node --import ./register-loader.mjs ./node_modules/nuxt/bin/nuxt.mjs prepare",
    "release": "pnpm run lint && pnpm run build && changelogen --patch --release && git push --follow-tags",
    "analyze": "nuxi analyze",
    "clean": "nuxi cleanup && rm -rf node_modules/.cache",
    "typecheck": "nuxi typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.1.1",
    "@iconify-json/carbon": "^1.2.14",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/prime": "^1.2.4",
    "@iconify-json/tabler": "^1.2.23",
    "@iconify-json/twemoji": "^1.2.4",
    "@nuxt/content": "^3.8.0",
    "@nuxt/devtools": "3.0.1",
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^3.19.2",
    "@nuxt/test-utils": "^3.20.1",
    "@pinia/nuxt": "^0.9.0",
    "@primeuix/themes": "^1.2.3",
    "@primevue/nuxt-module": "^4.4.1",
    "@primevue/themes": "^4.2.5",
    "@tiptap/extension-highlight": "^2.11.5",
    "@tiptap/extension-text-align": "^2.11.5",
    "@tiptap/extension-text-style": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@tiptap/vue-3": "^2.11.5",
    "@unocss/nuxt": "^66.5.4",
    "@unocss/preset-icons": "^66.5.4",
    "@vitest/ui": "^4.0.7",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/nuxt": "^12.5.0",
    "c8": "^10.1.3",
    "changelogen": "^0.5.7",
    "eslint": "^9.20.0",
    "happy-dom": "^17.0.0",
    "jsdom": "^26.0.0",
    "magicast": "^0.5.1",
    "nuxt": "^4.2.1",
    "nuxt-lodash": "^2.5.3",
    "sass": "1.78.0",
    "typescript": "^5.7.3",
    "unocss": "^66.5.4",
    "unstorage": "^1.14.4",
    "vitest": "^4.0.7",
    "vue-router": "^4.5.1",
    "vue-sidebar-menu": "^5.4.2"
  },
  "packageManager": "pnpm@9.15.3+sha512.1f79bc245a66eb0b07c5d4d83131240774642caaa86ef7d0434ab47c0d16f66b04e21e0c086eb61e62c77efc4d7f7ec071afad3796af64892fae66509173893a",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@guolao/vue-monaco-editor": "^1.5.5",
    "@handsontable/vue3": "^15.3.0",
    "@univerjs/presets": "^0.6.6",
    "@vue/composition-api": "^1.7.2",
    "ag-charts-vue3": "^11.3.2",
    "ag-grid-enterprise": "^33.3.2",
    "ag-grid-vue3": "^33.3.2",
    "autobahn-browser": "^22.11.1",
    "danfojs": "^1.2.0",
    "handsontable": "^15.3.0",
    "localbase": "^0.7.7",
    "lodash": "^4.17.21",
    "monaco-editor": "^0.52.2",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "uuid": "^11.1.0",
    "vue-multiselect": "^3.3.1",
    "vue3-grid-layout-next": "^1.0.7",
    "yup": "^1.7.1"
  }
}
