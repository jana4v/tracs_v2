# Disable symlinks and use hoisted node_modules structure
node-linker=hoisted
symlink=false

# Store node_modules in project directory (not global store)
store-dir=node_modules/.pnpm-store
virtual-store-dir=node_modules/.pnpm

# Disable global store to ensure everything is local
enable-global-dir=false
shared-workspace-lockfile=false

# Ensure all dependencies are installed locally
prefer-offline=false
strict-peer-dependencies=false

