{
  "name": "nuxt3-primevue-starter",
  "type": "module",
  "version": "2.2.6",
  "license": "MIT",
  "scripts": {
    "build": "node ./run-nuxt.mjs build",
    "dev": "node ./run-nuxt.mjs dev --host 0.0.0.0",
    "generate": "node ./run-nuxt.mjs generate",
    "preview": "node ./run-nuxt.mjs preview",
    "module": "nuxi init -t module my-module",
    "start": "node .output/server/index.mjs",
    "lint": "eslint ./app",
    "lint:fix": "eslint --fix ./app",
    "test:ui": "vitest --ui",
    "test:unit": "vitest --run --reporter verbose",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node ./run-nuxt.mjs prepare",
    "release": "yarn lint && yarn build && changelogen --patch --release && git push --follow-tags",
    "analyze": "nuxi analyze",
    "clean": "nuxi cleanup && rm -rf node_modules/.cache",
    "typecheck": "nuxi typecheck",
    "pwa-assets": "pwa-assets-generator --preset minimal-2023 public/icon.svg"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.1.1",
    "@iconify-json/carbon": "^1.2.14",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/prime": "^1.2.4",
    "@iconify-json/tabler": "^1.2.23",
    "@iconify-json/twemoji": "^1.2.4",
    "@nuxt/content": "^3.8.0",
    "@nuxt/devtools": "3.0.1",
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^3.19.2",
    "@nuxt/test-utils": "^3.20.1",
    "@pinia/nuxt": "^0.9.0",
    "@primeuix/themes": "^1.2.3",
    "@primevue/nuxt-module": "^4.4.1",
    "@tiptap/extension-highlight": "^2.11.5",
    "@tiptap/extension-text-align": "^2.11.5",
    "@tiptap/extension-text-style": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@tiptap/vue-3": "^2.11.5",
    "@unocss/nuxt": "^66.5.4",
    "@unocss/preset-icons": "^66.5.4",
    "@vite-pwa/assets-generator": "^0.2.6",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitest/ui": "^4.0.7",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/nuxt": "^12.5.0",
    "c8": "^10.1.3",
    "changelogen": "^0.5.7",
    "eslint": "^9.20.0",
    "happy-dom": "^17.0.0",
    "jsdom": "^26.0.0",
    "magicast": "^0.5.1",
    "nuxt": "^4.2.1",
    "nuxt-lodash": "^2.5.3",
    "sass": "1.78.0",
    "typescript": "^5.7.3",
    "unocss": "^66.5.4",
    "unstorage": "^1.14.4",
    "vitest": "^4.0.7",
    "vue-router": "^4.5.1",
    "vue-sidebar-menu": "^5.4.2"
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@guolao/vue-monaco-editor": "^1.5.5",
    "@handsontable/vue3": "^17.0.0",
    "@univerjs/presets": "^0.6.6",
    "ag-charts-vue3": "^11.3.2",
    "ag-grid-enterprise": "35.1.0",
    "ag-grid-vue3": "35.1.0",
    "better-sqlite3": "^12.6.2",
    "danfojs": "^1.2.0",
    "handsontable": "^17.0.0",
    "localbase": "^0.7.7",
    "lodash": "^4.17.21",
    "monaco-editor": "^0.52.2",
    "mqtt": "^5.15.0",
    "nats.ws": "^1.30.2",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "uuid": "^11.1.0",
    "vue-multiselect": "^3.3.1",
    "vue3-grid-layout-next": "^1.0.7",
    "yup": "^1.7.1"
  }
}
